        "query": "INSERT INTO events (type, payload)\nVALUES (\n  'handoff_complete',\n  jsonb_build_object(\n    'lead_id', '{{ $node[\"Persist Lead\"].json.lead_id }}',\n    'agent_id', {{ $node[\"Pick Agent\"].json.agent_id }},\n    'agent_name', '{{ $node[\"Pick Agent\"].json.agent_name }}',\n    'conversation_id', '{{ $node[\"Validate Input\"].json.chatwoot_conversation_id }}',\n    'phone', '{{ $node[\"Validate Input\"].json.phone }}',\n    'class', '{{ $node[\"Validate Input\"].json.class }}',\n    'source', '{{ $node[\"Validate Input\"].json.source }}',\n    'ja_compra_asx_regiao', '{{ $node[\"Validate Input\"].json.ja_compra_asx_regiao }}',\n    'nfs_enviadas', '{{ $node[\"Validate Input\"].json.nfs_enviadas }}',\n    'empresa_recente', '{{ $node[\"Validate Input\"].json.empresa_recente }}'\n  )\n);",
        "options": {}
