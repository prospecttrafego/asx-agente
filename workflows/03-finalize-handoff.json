        "sendBody": true,
        "specifyBody": "keypair",
        "options": {},
        "bodyParameters": {
          "parameters": [
            {
              "name": "number",
              "value": "={{ $node['Pick Agent'].json.agent_phone }}"
            },
            {
              "name": "text",
              "value": "={{ '*NOVO LEAD QUALIFICADO*' + ($node['Validate Input'].json.source === 'facebook_form' ? ' (via Formulario Facebook)' : '') + '\\n\\n' + 'Nome: ' + $node['Validate Input'].json.nome + '\\n' + 'Empresa: ' + $node['Validate Input'].json.empresa + '\\n' + 'Regiao: ' + $node['Validate Input'].json.regiao + '\\n' + 'Tel: +' + $node['Validate Input'].json.phone + '\\n\\n' + 'Score: ' + $node['Validate Input'].json.class + '\\n\\n' + ($node['Validate Input'].json.ja_compra_asx === 'sim' ? 'Ja compra ASX de: ' + $node['Validate Input'].json.fornecedor_atual : 'Ainda nao compra ASX') + '\\n' + ($node['Validate Input'].json.nfs_enviadas === 'true' ? 'NFs: Enviadas' : ($node['Validate Input'].json.empresa_recente === 'true' ? 'NFs: Empresa nova' : 'NFs: Nao enviadas')) + '\\n\\n' + 'Entre em contato\\!' }}"
            }
          ]
        }
      },
