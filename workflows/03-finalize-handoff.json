        "query": "INSERT INTO assignments (lead_id, assignee_id, assigned_at)\nVALUES (\n  '{{ $node[\"Persist Lead\"].json.lead_id }}',\n  {{ $node[\"Pick Agent\"].json.agent_id }},\n  NOW()\n)\nRETURNING id AS assignment_id;",
        "options": {}
