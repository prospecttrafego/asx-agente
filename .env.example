# ============================================================
# ASX-Agente — Variaveis de Ambiente
# ============================================================
# Copie este arquivo para .env e preencha com seus valores reais.
# NUNCA commite o .env com secrets no repositorio.
# ============================================================

# --- N8N (Orquestrador de Workflows) ---

N8N_API_URL=https://seu-n8n.exemplo.com/api/v1
N8N_API_KEY=seu_api_key_aqui
N8N_WEBHOOK_URL=https://seu-n8n.exemplo.com/

# --- SUPABASE (Banco de Dados) ---

SUPABASE_URL=https://seu-projeto.supabase.co
SUPABASE_KEY=sua_anon_key_aqui
SUPABASE_SERVICE_KEY=sua_service_role_key_aqui
SUPABASE_CONNECTION_STRING=postgresql://postgres.seu-projeto:SENHA@aws-1-sa-east-1.pooler.supabase.com:5432/postgres

# --- CHATWOOT (CRM / Painel de Atendimento) ---

CHATWOOT_URL=https://seu-chatwoot.exemplo.com
CHATWOOT_ACCOUNT_ID=1
CHATWOOT_API_TOKEN=seu_api_token_aqui

# IDs das Inboxes
CHATWOOT_INBOX_SDR_ID=1
CHATWOOT_INBOX_QUEILA_ID=2
CHATWOOT_INBOX_TIAGO_ID=3

# --- EVOLUTION API (WhatsApp Gateway via Baileys) ---

EVOLUTION_URL=https://sua-evolution.exemplo.com/
EVOLUTION_API_KEY=sua_api_key_aqui
EVOLUTION_INSTANCE=ASX_SDR
TOKEN_INSTANCE=seu_token_instance_aqui

# Webhook configurado na Evolution API (POST):
# https://seu-n8n.exemplo.com/webhook/asx-sdr
# Habilitar: webhook, webhook Base64, Messages_Upsert

# --- OPENAI (LLM) ---

OPENAI_API_KEY=sk-proj-sua_key_aqui

# --- CNPJA (Enriquecimento de CNPJ) ---
# Obter em: https://cnpja.com

CNPJA_API_KEY=sua_api_key_aqui

# --- OCR SPACE (Leitura de Notas Fiscais) ---
# Obter em: https://ocr.space/ocrapi

OCR_SPACE_API_KEY=sua_api_key_aqui

# --- VENDEDORES ---

# Queila
AGENT_QUEILA_ID=2
AGENT_QUEILA_PHONE=5500000000000
AGENT_QUEILA_INBOX_ID=2

# Tiago
AGENT_TIAGO_ID=3
AGENT_TIAGO_PHONE=5500000000000
AGENT_TIAGO_INBOX_ID=3

# --- CREDENCIAIS NOMEADAS NO N8N ---
# Nomes das credentials configuradas dentro do n8n

CREDENTIAL_NAME_SUPABASE="Supabase ASX"
CREDENTIAL_NAME_CHATWOOT="Chatwoot ASX"
CREDENTIAL_NAME_EVOLUTION="Evolution ASX"
CREDENTIAL_NAME_OPENAI="OpenAI GPT-4"

# --- POSTGRES (acessos diretos, se necessario) ---

# N8N Postgres
N8N_POSTGRES_HOST=seu-host.exemplo.com
N8N_POSTGRES_PORT=5432
N8N_POSTGRES_DB=agents
N8N_POSTGRES_USER=postgres
N8N_POSTGRES_PASSWORD=sua_senha_aqui

# Chatwoot Postgres
CHATWOOT_POSTGRES_HOST=seu-host.exemplo.com
CHATWOOT_POSTGRES_PORT=5433
CHATWOOT_POSTGRES_DB=agents
CHATWOOT_POSTGRES_USER=postgres
CHATWOOT_POSTGRES_PASSWORD=sua_senha_aqui
